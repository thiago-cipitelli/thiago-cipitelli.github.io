---
import { experience, education } from '../data/experience';
import { getLangFromUrl, useTranslations, pick } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="experiencia" class="section">
  <div class="container">
    <h2 class="section-title" data-reveal>{t('nav.experience')}</h2>

    <ol class="timeline">
      {experience.map((job, i) => (
        <li data-reveal style={`--reveal-delay: ${i * 0.06}s`}>
          <span class="node" aria-hidden="true"></span>
          <article class="card entry">
            <header>
              <div>
                <h3>{pick(lang, job.role)}</h3>
                <p class="company">
                  @ <span>{job.company}</span>
                </p>
              </div>
              <p class="period mono">{pick(lang, job.period)}</p>
            </header>
            <ul class="bullets">
              {job.bullets.map((b) => (
                <li>{pick(lang, b)}</li>
              ))}
            </ul>
            <footer class="tags">
              {job.tech.map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </footer>
          </article>
        </li>
      ))}
    </ol>

    <div class="education" data-reveal>
      <h3 class="mono edu-title">
        <span class="hash">#</span> {t('experience.education')}
      </h3>
      {education.map((edu) => (
        <p class="edu-entry">
          <span class="mono period">{edu.period}</span>
          <span>
            {pick(lang, edu.title)}
            {pick(lang, edu.note) && (
              <span class="mono note"> — {pick(lang, edu.note)}</span>
            )}
          </span>
        </p>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    position: relative;
    display: grid;
    gap: 1.75rem;
  }
  /* git-log line */
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 10px;
    bottom: 10px;
    width: 2px;
    background: linear-gradient(var(--accent-deep), var(--border));
  }
  .timeline li {
    position: relative;
    padding-left: 2.4rem;
  }
  /* commit node */
  .node {
    position: absolute;
    left: 0;
    top: 1.6rem;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--bg);
    border: 3px solid var(--accent);
    box-shadow: 0 0 12px var(--accent-glow-strong);
  }
  .entry {
    padding: 1.5rem 1.6rem;
  }
  .entry header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .entry h3 {
    font-size: 1.15rem;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .company {
    color: var(--text-faint);
  }
  .company span {
    color: var(--accent);
    font-weight: 600;
  }
  .period {
    font-size: 0.78rem;
    color: var(--text-faint);
    white-space: nowrap;
  }
  .bullets {
    margin: 1rem 0 1.2rem;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.45rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .bullets li::marker {
    content: '– ';
    color: var(--accent);
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .education {
    margin-top: 3rem;
    padding-left: 2.4rem;
  }
  .edu-title {
    font-size: 0.95rem;
    margin-bottom: 0.9rem;
  }
  .hash {
    color: var(--text-faint);
  }
  .edu-entry {
    display: flex;
    gap: 1.25rem;
    align-items: baseline;
    color: var(--text-muted);
    padding-block: 0.3rem;
    flex-wrap: wrap;
  }
  .edu-entry .period {
    color: var(--accent);
  }
  .note {
    font-size: 0.8rem;
    color: var(--text-faint);
  }

  @media (max-width: 640px) {
    .timeline li {
      padding-left: 1.9rem;
    }
    .education {
      padding-left: 1.9rem;
    }
  }
</style>
