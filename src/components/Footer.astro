---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="contato" class="section contact">
  <div class="container">
    <h2 class="section-title" data-reveal>{t('nav.contact')}</h2>

    <div class="cta-block" data-reveal>
      <h3>{t('contact.title')}</h3>
      <p>{t('contact.text')}</p>

      <div class="links">
        <a
          class="btn mono"
          href="mailto:cipitelliprata@gmail.com"
        >
          <svg
            width="17"
            height="17"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m2 7 10 7L22 7"></path>
          </svg>
          {t('contact.email')}
        </a>
        <a
          class="icon-link"
          href="https://github.com/thiago-cipitelli"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          title="GitHub"
        >
          <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path
              d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
            />
          </svg>
        </a>
        <a
          class="icon-link"
          href="https://www.linkedin.com/in/thiago-cipitelli/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          title="LinkedIn"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.85 3.36-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.72v20.55C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.72C24 .77 23.2 0 22.22 0Z"
            />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<footer>
  <div class="container footer-inner">
    <p class="mono">
      <span class="prompt">❯</span> thiago-cipitelli © {new Date().getFullYear()}
    </p>
    <p class="mono built">{t('footer.built')}</p>
  </div>
</footer>

<style>
  .contact {
    position: relative;
  }
  .cta-block {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
    padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 4vw, 3rem);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background:
      radial-gradient(400px 200px at 50% 0%, var(--accent-glow), transparent 70%),
      var(--bg-raised);
  }
  h3 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .cta-block p {
    margin-top: 0.9rem;
    color: var(--text-muted);
  }
  .links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.9rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.88rem;
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
    background: var(--accent-deep);
    color: #fff;
    box-shadow: 0 4px 20px var(--accent-glow-strong);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .btn:hover {
    color: #fff;
    transform: translateY(-2px);
    box-shadow: 0 8px 28px var(--accent-glow-strong);
  }
  .icon-link {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 8px;
    border: 1px solid var(--border-bright);
    color: var(--text-muted);
    transition: color 0.2s, border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .icon-link:hover {
    color: var(--accent);
    border-color: var(--accent-deep);
    box-shadow: 0 0 16px var(--accent-glow);
    transform: translateY(-2px);
  }

  footer {
    border-top: 1px solid var(--border);
    padding-block: 1.5rem;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
    color: var(--text-faint);
  }
  .prompt {
    color: var(--accent);
  }
</style>
