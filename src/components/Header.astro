---
import ThemeToggle from './ThemeToggle.astro';
import { getLangFromUrl, useTranslations, altLocalePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const nav = [
  { href: '#experiencia', label: t('nav.experience') },
  { href: '#projetos', label: t('nav.projects') },
  { href: '#tecnologias', label: t('nav.skills') },
  { href: '#contato', label: t('nav.contact') },
];
---

<header>
  <div class="container inner">
    <a class="logo mono" href={lang === 'en' ? '/en/' : '/'} aria-label="Home">
      <span class="prompt">❯</span> thiago-cipitelli
    </a>

    <nav aria-label="Main">
      {nav.map((item) => (
        <a class="mono nav-link" href={item.href}>
          <span class="dot">./</span>{item.label}
        </a>
      ))}
    </nav>

    <div class="actions">
      <a
        class="mono lang-toggle"
        href={altLocalePath(lang)}
        aria-label={t('lang.switch')}
        title={t('lang.switch')}
      >
        {lang === 'en' ? 'pt' : 'en'}
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 3.75rem;
  }
  .logo {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
  }
  .logo .prompt {
    color: var(--accent);
  }
  nav {
    display: flex;
    gap: clamp(0.75rem, 2.5vw, 1.75rem);
    flex-wrap: wrap;
  }
  .nav-link {
    font-size: 0.82rem;
    color: var(--text-muted);
    transition: color 0.2s;
  }
  .nav-link:hover {
    color: var(--accent);
  }
  .dot {
    color: var(--text-faint);
  }
  .actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .lang-toggle {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-muted);
    transition: color 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .lang-toggle:hover {
    color: var(--accent);
    border-color: var(--accent-deep);
    box-shadow: 0 0 12px var(--accent-glow);
  }

  @media (max-width: 640px) {
    nav {
      display: none;
    }
  }
</style>
