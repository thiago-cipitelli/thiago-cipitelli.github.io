---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="hero">
  <div class="container inner">
    <div class="intro" data-reveal>
      <p class="mono greeting">{t('hero.greeting')}</p>
      <h1>Thiago Cipitelli</h1>
      <p class="role mono">
        <span class="accent">&lt;</span>{t('hero.role')}<span class="accent">
          /&gt;</span
        >
      </p>
      <p class="tagline">{t('hero.tagline')}</p>
      <div class="ctas">
        <a class="btn primary mono" href="#projetos">{t('hero.cta.projects')}</a>
        <a class="btn ghost mono" href="#contato">{t('hero.cta.contact')}</a>
      </div>
    </div>

    <div class="terminal card" data-reveal style="--reveal-delay: 0.15s">
      <div class="titlebar">
        <span class="light red"></span>
        <span class="light yellow"></span>
        <span class="light green"></span>
        <span class="title mono">thiago@dev: ~</span>
      </div>
      <pre class="screen mono" aria-hidden="true"><code><span class="prompt">$</span> whoami
<span class="out">thiago-cipitelli</span>
<span class="prompt">$</span> cat about.yml
<span class="key">role:</span> <span class="val">{t('hero.role')}</span>
<span class="key">stack:</span> <span class="val">[rails, postgres, redis, go]</span>
<span class="key">location:</span> <span class="val">{t('hero.terminal.location')}</span>
<span class="key">education:</span> <span class="val">{t('hero.terminal.education')}</span>
<span class="key">status:</span> <span class="status">● {t('hero.terminal.status')}</span>
<span class="prompt">$</span> <span class="cursor">▋</span></code></pre>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-block: clamp(4rem, 10vw, 8rem);
    overflow: hidden;
  }
  /* atmosphere: radial glow + faint grid */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(600px 400px at 75% 20%, var(--accent-glow), transparent 70%),
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size:
      auto,
      44px 44px,
      44px 44px;
    opacity: 0.5;
    -webkit-mask-image: radial-gradient(ellipse 90% 85% at 50% 40%, black 30%, transparent 75%);
    mask-image: radial-gradient(ellipse 90% 85% at 50% 40%, black 30%, transparent 75%);
    pointer-events: none;
  }
  .inner {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .greeting {
    color: var(--accent);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
  }
  .role {
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    color: var(--text-muted);
    margin-top: 0.75rem;
  }
  .accent {
    color: var(--accent);
  }
  .tagline {
    margin-top: 1.25rem;
    max-width: 44ch;
    color: var(--text-muted);
  }
  .ctas {
    display: flex;
    gap: 0.9rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  .btn {
    font-size: 0.88rem;
    padding: 0.65rem 1.4rem;
    border-radius: 8px;
    transition: transform 0.2s, box-shadow 0.2s, background 0.2s, border-color 0.2s;
  }
  .btn.primary {
    background: var(--accent-deep);
    color: #fff;
    box-shadow: 0 4px 20px var(--accent-glow-strong);
  }
  .btn.primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px var(--accent-glow-strong);
  }
  .btn.ghost {
    border: 1px solid var(--border-bright);
    color: var(--text);
  }
  .btn.ghost:hover {
    border-color: var(--accent-deep);
    box-shadow: 0 0 16px var(--accent-glow);
  }

  /* terminal window */
  .terminal {
    background: var(--bg-terminal);
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45), 0 0 40px var(--accent-glow);
    overflow: hidden;
  }
  .titlebar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--border);
  }
  .light {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .red {
    background: #f87171;
  }
  .yellow {
    background: #fbbf24;
  }
  .green {
    background: #4ade80;
  }
  .title {
    margin-left: 0.5rem;
    font-size: 0.72rem;
    color: #5c6a7d;
  }
  .screen {
    padding: 1.2rem 1.3rem 1.4rem;
    font-size: 0.82rem;
    line-height: 1.85;
    overflow-x: auto;
    color: #d9e1ee;
  }
  .prompt {
    color: #4ade80;
  }
  .out {
    color: #d9e1ee;
  }
  .key {
    color: #4d9fff;
  }
  .val {
    color: #c9d4e6;
  }
  .status {
    color: #4ade80;
  }
  .cursor {
    color: #4d9fff;
  }
  @media (prefers-reduced-motion: no-preference) {
    .cursor {
      animation: blink 1.1s steps(1) infinite;
    }
    @keyframes blink {
      50% {
        opacity: 0;
      }
    }
  }

  @media (max-width: 860px) {
    .inner {
      grid-template-columns: 1fr;
    }
    .terminal {
      max-width: 560px;
    }
  }
</style>
