---
import { projects } from '../data/projects';
import { getLangFromUrl, useTranslations, pick } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="projetos" class="section">
  <div class="container">
    <h2 class="section-title" data-reveal>{t('nav.projects')}</h2>

    <div class="grid">
      {projects.map((project, i) => (
        <a
          class="card project"
          href={project.repo}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${project.name} — ${t('projects.viewRepo')}`}
          data-reveal
          style={`--reveal-delay: ${(i % 3) * 0.08}s`}
        >
          <header class="mono">
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8ZM5 12.25a.25.25 0 0 1 .25-.25h3.5a.25.25 0 0 1 .25.25v3.25a.25.25 0 0 1-.4.2l-1.45-1.087a.249.249 0 0 0-.3 0L5.4 15.7a.25.25 0 0 1-.4-.2Z"
              />
            </svg>
            <span class="name">{project.name}</span>
            <span class="arrow" aria-hidden="true">↗</span>
          </header>
          <p class="desc">{pick(lang, project.description)}</p>
          <footer>
            <span class="lang mono">
              <span
                class="lang-dot"
                style={`background:${project.languageColor}`}
              ></span>
              {project.language}
            </span>
            <span class="tags">
              {project.tags.slice(0, 3).map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </span>
          </footer>
        </a>
      ))}
    </div>

    <p class="more mono" data-reveal>
      {t('projects.footer')}
      <a
        href="https://github.com/thiago-cipitelli"
        target="_blank"
        rel="noopener noreferrer">github.com/thiago-cipitelli</a
      >
    </p>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .project {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    padding: 1.4rem 1.5rem;
    color: inherit;
  }
  .project:hover {
    transform: translateY(-3px);
  }
  .project header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text-faint);
  }
  .name {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text);
  }
  .project:hover .name {
    color: var(--accent);
  }
  .arrow {
    margin-left: auto;
    color: var(--text-faint);
    transition: transform 0.2s, color 0.2s;
  }
  .project:hover .arrow {
    color: var(--accent);
    transform: translate(2px, -2px);
  }
  .desc {
    font-size: 0.92rem;
    color: var(--text-muted);
    flex-grow: 1;
  }
  .project footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .lang {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }
  .lang-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }
  .tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .more {
    margin-top: 2.5rem;
    font-size: 0.85rem;
    color: var(--text-faint);
    text-align: center;
  }
</style>
