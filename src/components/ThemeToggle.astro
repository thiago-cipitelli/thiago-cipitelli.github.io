---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const t = useTranslations(getLangFromUrl(Astro.url));
---

<button id="theme-toggle" aria-label={t('theme.toggle')} title={t('theme.toggle')}>
  <svg
    class="icon-sun"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"
    ></path>
  </svg>
  <svg
    class="icon-moon"
    xmlns="http://www.w3.org/2000/svg"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8z"></path>
  </svg>
</button>

<style>
  button {
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: color 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  button:hover {
    color: var(--accent);
    border-color: var(--accent-deep);
    box-shadow: 0 0 12px var(--accent-glow);
  }
  .icon-sun {
    display: none;
  }
  :global([data-theme='dark']) .icon-sun {
    display: block;
  }
  :global([data-theme='dark']) .icon-moon {
    display: none;
  }
</style>

<script>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
